# Copy to .env on the GCP VM (do not commit .env).
# Used when starting the app with: export $(grep -v '^#' .env | xargs)

SPRING_PROFILES_ACTIVE=cloud

DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=ticketsystem
DB_USER=your-db-user
DB_PASSWORD=your-db-password

JWT_SECRET=change-me-to-at-least-32-characters-long
EXTERNAL_SYSTEM_URL=https://your-external-service.example/
